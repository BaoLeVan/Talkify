# ============================================================
#  Environment Variables — Chat Application
#  Copy file này thành .env và chỉnh sửa giá trị
#  KHÔNG commit file .env vào source control
# ============================================================

# ─── Application ───────────────────────────────────────────
APP_PORT=8080
SPRING_PROFILES_ACTIVE=docker
SNOWFLAKE_MACHINE_ID=1

# ─── PostgreSQL ────────────────────────────────────────────
POSTGRES_PORT=5432
POSTGRES_DB=chat_db
POSTGRES_USER=chatuser
POSTGRES_PASSWORD=chatpassword_change_in_prod

# ─── MongoDB ───────────────────────────────────────────────
MONGO_PORT=27017
MONGO_DB=chat_db
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=rootpassword_change_in_prod
MONGO_USER=chatuser
MONGO_PASSWORD=chatpassword_change_in_prod

# ─── Redis ─────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=redispassword_change_in_prod

# ─── Kafka ─────────────────────────────────────────────────
KAFKA_PORT=9092
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# ─── MinIO ─────────────────────────────────────────────────
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123_change_in_prod
MINIO_BUCKET=chat-media

# ─── JWT ───────────────────────────────────────────────────
# Thay bằng random 256-bit secret trong production
JWT_SECRET=change-this-to-a-very-long-random-secret-key-in-production
JWT_ACCESS_EXPIRATION_MS=900000      # 15 phút
JWT_REFRESH_EXPIRATION_MS=2592000000 # 30 ngày

# ─── Monitoring ────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123_change_in_prod
# ─── Logging (ELK Stack) ───────────────────────────────────
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601
ELASTIC_PASSWORD=                        # để trống khi x-pack.security disabled
